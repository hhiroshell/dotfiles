# for zsh installed with apt on Ubuntu.
# cf. https://github.com/zimfw/zimfw/wiki/Troubleshooting#completion-is-not-working
skip_global_compinit=1

# XDG Base Directory Specification
export XDG_CONFIG_HOME="${HOME}/.config"
export XDG_DATA_DIRS="/var/lib/flatpak/exports/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"


# =====
# PATH
# =====

# some applications (e.g., qmk, Claude Code) will be placed here
# cf. https://docs.qmk.fm/#/newbs_getting_started?id=set-up-qmk
PATH="$HOME/.local/bin:$PATH"

# pkgmux
export PATH="${HOME}/src/github.com/hhiroshell/dotfiles/pkgmux:${PATH}"

# krew
export PATH="$PATH:${KREW_ROOT:-$HOME/.krew}/bin"

# Go
# cf. https://go.dev/doc/install
export PATH="$PATH:/usr/local/go/bin"
export GOPATH="$HOME/.go"
export PATH="$PATH:$GOPATH/bin"

# Rust
[[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"

